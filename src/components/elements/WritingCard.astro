---
// assets
import Calendar from "../../assets/icons/Calendar.astro";
import Website from "../../assets/icons/Website.astro";

// components
import Text from "../elements/Text.astro";
import Heading from "../elements/Heading.astro";
import Link from "../elements/Link.astro";
import Tag from "../elements/Tag.astro";

const {
    title,
    publisher,
    link,
    type,
    isAwarded = false,
    monthYearAwarded,
    honour,
    competition
} = Astro.props;
---

<div class={`border-2 border-base-900 ${isAwarded ? "ring-2 ring-green-400/40 shadow-[0_0_24px_rgba(74,222,128,0.20)]" : ""}`}>
    <div class="bg-base-900 p-16 flex flex-col gap-16">
        <Heading tagName="h3" tagSize="h3">{title}</Heading>

        <div class="flex md:flex-row md:gap-32 flex-col gap-16">
            <div class="flex flex-row gap-8 text-base-100 items-center">
                <Text variant={'sm'} class="text-base-500">{publisher}</Text>
            </div>

            {
                link && (
                    <div class="flex flex-row gap-8 text-base-100 items-center">
                        <Website width={20} height={20} fill="currentColor" />
                        <Link variant={'inline'} href={link} text="Read" newWindow />
                    </div>
                )
            }
        </div>
    </div>

    <div class="p-16 flex flex-col gap-16">
        <div class="flex flex-row gap-16 flex-wrap">
            <Tag title={type} />

            {
                isAwarded && honour && (
                    <Tag title="Awarded" />
                )
            }
        </div>

        {
            isAwarded && (
                <div class="flex flex-col gap-8">
                    <Text variant={'sm'} class="text-base-400">
                        {honour}
                    </Text>

                    <div class="flex flex-row gap-8 text-base-100 items-center">
                        <Calendar width={20} height={20} fill="currentColor" />
                        <Text variant={'sm'} class="text-base-500">
                            {monthYearAwarded}
                            {competition ? ` — ${competition}` : ""}
                        </Text>
                    </div>
                </div>
            )
        }
    </div>
</div>