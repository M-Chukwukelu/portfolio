---
const pathname = Astro.url.pathname;
// components
import Link from "../elements/Link.astro"

const base = import.meta.env.BASE_URL;

// content
const nav = [
  { title: "/home", href: base },
  { title: "/projects", href: `${base}projects` },
  { title: "/about", href: `${base}about` },
  { title: "/writing", href: `${base}writing` },
  { title: "/awards", href: `${base}awards` },
  { title: "/contact", href: `${base}contact` },
]
---

<nav class="bg-base-900 flex flex-row flex-wrap sticky top-0">
    {
        nav.map((navLink) => {
            const isActive = navLink.href === "/" ? pathname === "/" : pathname.startsWith(navLink.href);
        return (
            <Link
                variant={'nav'} 
                href={navLink.href}
                text={navLink.title}
                aria-current={isActive ? "page" : undefined}
                class={isActive ? "bg-base-950 border-t-2 border-base-900" : "" }
            />
        )})
    }
</nav>